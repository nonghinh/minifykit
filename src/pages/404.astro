---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { TOOLS } from "~/lib/processors";
---

<BaseLayout
  title="Page not found — MinifyKit"
  description="The page you're looking for doesn't exist. Try one of MinifyKit's tools below."
  noindex={true}
>
  <div class="flex min-h-screen flex-col">
    <header
      class="border-b border-slate-200 dark:border-slate-800"
    >
      <div
        class="mx-auto flex h-14 w-full max-w-6xl items-center px-4 sm:px-6"
      >
        <a
          href="/"
          class="flex items-center gap-2 text-slate-900 dark:text-slate-50"
        >
          <span
            class="inline-flex h-7 w-7 items-center justify-center rounded-md bg-slate-900 font-mono text-xs font-bold text-slate-50 dark:bg-slate-100 dark:text-slate-900"
            aria-hidden="true">{`{}`}</span>
          <span class="text-sm font-semibold tracking-tight">MinifyKit</span>
        </a>
      </div>
    </header>

    <main
      class="mx-auto flex w-full max-w-3xl flex-1 flex-col items-center justify-center px-4 py-16 text-center sm:px-6"
    >
      <p
        class="font-mono text-sm font-medium uppercase tracking-wide text-slate-500 dark:text-slate-400"
      >
        404
      </p>
      <h1
        class="mt-3 text-balance text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-50"
      >
        Page not found
      </h1>
      <p class="mt-3 max-w-lg text-pretty text-base text-slate-600 dark:text-slate-400">
        The page you're looking for doesn't exist. Try one of these tools
        instead.
      </p>

      <div
        class="mt-8 grid w-full gap-2 sm:grid-cols-2"
      >
        {
          TOOLS.map((tool) => (
            <a
              href={tool.slug}
              class="rounded-md border border-slate-200 bg-white px-4 py-3 text-left text-sm font-medium text-slate-900 transition-colors hover:border-slate-300 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2 dark:border-slate-800 dark:bg-slate-950 dark:text-slate-50 dark:hover:border-slate-700 dark:hover:bg-slate-900"
            >
              {tool.label}
              <span class="block text-xs font-normal text-slate-500 dark:text-slate-400">
                {tool.slug}
              </span>
            </a>
          ))
        }
      </div>

      <a
        href="/"
        class="mt-10 inline-flex items-center gap-2 text-sm font-medium text-slate-900 hover:underline dark:text-slate-50"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M19 12H5M12 19l-7-7 7-7"></path>
        </svg>
        Back to home
      </a>
    </main>
  </div>
</BaseLayout>
