---
import { TOOLS } from "~/lib/processors";

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

const tabBase =
  "inline-flex shrink-0 cursor-pointer items-center justify-center whitespace-nowrap rounded-md px-3 py-1.5 text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2";
const tabInactive =
  "text-slate-600 hover:text-slate-900 hover:bg-slate-100 dark:text-slate-400 dark:hover:text-slate-100 dark:hover:bg-slate-800";
const tabActive =
  "bg-slate-900 text-slate-50 shadow-sm dark:bg-slate-100 dark:text-slate-900";
---

<header
  class="sticky top-0 z-30 border-b border-slate-200 bg-white/80 backdrop-blur dark:border-slate-800 dark:bg-slate-950/80"
>
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6">
    <div class="flex h-14 items-center justify-between gap-3 md:gap-4">
      <a
        href="/"
        class="flex shrink-0 items-center gap-2 text-slate-900 dark:text-slate-50"
      >
        <span
          class="inline-flex h-7 w-7 items-center justify-center rounded-md bg-slate-900 font-mono text-xs font-bold text-slate-50 dark:bg-slate-100 dark:text-slate-900"
          aria-hidden="true">{`{}`}</span>
        <span class="text-sm font-semibold tracking-tight">MinifyKit</span>
      </a>

      <nav
        aria-label="Tools"
        class="hidden min-w-0 flex-1 overflow-x-auto px-1 md:block [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
      >
        <div
          class="mx-auto inline-flex w-max items-center gap-1 rounded-lg border border-slate-200 bg-slate-50 p-1 dark:border-slate-800 dark:bg-slate-900"
        >
          {
            TOOLS.map((t) => (
              <a
                href={t.slug}
                aria-current={t.slug === currentSlug ? "page" : undefined}
                class:list={[
                  tabBase,
                  t.slug === currentSlug ? tabActive : tabInactive,
                ]}
              >
                {t.label}
              </a>
            ))
          }
        </div>
      </nav>

      <button
        type="button"
        data-theme-toggle
        aria-label="Toggle theme"
        class="inline-flex h-9 w-9 shrink-0 cursor-pointer items-center justify-center rounded-md border border-slate-200 bg-white text-slate-600 transition-colors hover:bg-slate-50 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-slate-50"
      >
        <svg
          class="hidden h-4 w-4 dark:block"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
          ></path>
        </svg>
        <svg
          class="h-4 w-4 dark:hidden"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>

    <nav
      aria-label="Tools"
      class="-mx-4 overflow-x-auto px-4 pb-2 md:hidden [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
    >
      <div
        class="inline-flex w-max items-center gap-1 rounded-lg border border-slate-200 bg-slate-50 p-1 dark:border-slate-800 dark:bg-slate-900"
      >
        {
          TOOLS.map((t) => (
            <a
              href={t.slug}
              aria-current={t.slug === currentSlug ? "page" : undefined}
              class:list={[
                tabBase,
                t.slug === currentSlug ? tabActive : tabInactive,
              ]}
            >
              {t.label}
            </a>
          ))
        }
      </div>
    </nav>
  </div>
</header>
