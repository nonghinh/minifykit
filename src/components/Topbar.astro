---
import { TOOLS, type ToolMeta } from "~/lib/processors";

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

type Kind = ToolMeta["kind"];

interface MenuGroup {
  id: string;
  label: string;
  /** When set, render the panel as titled sub-sections in this order. */
  subKinds?: { kind: Kind; label: string }[];
  kinds: Kind[];
}

const MENUS: MenuGroup[] = [
  {
    id: "minify",
    label: "Minify",
    kinds: ["minify"],
  },
  {
    id: "format",
    label: "Format",
    kinds: ["format"],
  },
  {
    id: "encode",
    label: "Encode/Decode",
    kinds: ["encode", "decode", "hash", "generate", "count"],
    subKinds: [
      { kind: "encode", label: "Encode" },
      { kind: "decode", label: "Decode" },
      { kind: "hash", label: "Hash" },
      { kind: "generate", label: "Generate" },
      { kind: "count", label: "Analyze" },
    ],
  },
];

function toolsFor(kinds: Kind[]) {
  return TOOLS.filter((t) => kinds.includes(t.kind));
}

function isActiveMenu(menu: MenuGroup) {
  return toolsFor(menu.kinds).some((t) => t.slug === currentSlug);
}

const itemBase =
  "flex items-center justify-between gap-2 rounded-md px-2 py-1.5 text-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-1";
const itemActive =
  "bg-slate-900 font-medium text-slate-50 dark:bg-slate-100 dark:text-slate-900";
const itemInactive =
  "text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800";

const buttonBase =
  "inline-flex cursor-pointer items-center gap-1.5 rounded-md border px-2.5 py-1.5 text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2 sm:gap-2 sm:px-3";
const buttonActive =
  "border-slate-900 bg-slate-900 text-slate-50 dark:border-slate-100 dark:bg-slate-100 dark:text-slate-900";
const buttonInactive =
  "border-slate-200 bg-white text-slate-700 hover:bg-slate-50 hover:text-slate-900 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-slate-100";
---

<header
  class="sticky top-0 z-30 border-b border-slate-200 bg-white/80 backdrop-blur dark:border-slate-800 dark:bg-slate-950/80"
>
  <div
    class="mx-auto flex h-14 w-full max-w-6xl items-center justify-between gap-2 px-3 sm:gap-4 sm:px-6"
  >
    <a
      href="/"
      class="flex shrink-0 items-center gap-2 text-slate-900 dark:text-slate-50"
    >
      <span
        class="inline-flex h-7 w-7 items-center justify-center rounded-md bg-slate-900 font-mono text-xs font-bold text-slate-50 dark:bg-slate-100 dark:text-slate-900"
        aria-hidden="true">{`{}`}</span>
      <span class="hidden text-sm font-semibold tracking-tight sm:inline"
        >MinifyKit</span
      >
    </a>

    <nav
      aria-label="Tools"
      class="flex flex-1 items-center justify-center gap-1 sm:gap-2"
    >
      {
        MENUS.map((menu) => {
          const active = isActiveMenu(menu);
          return (
            <div class="relative">
              <button
                type="button"
                data-tools-menu-button
                data-menu-id={menu.id}
                aria-haspopup="menu"
                aria-expanded="false"
                aria-controls={`mk-menu-${menu.id}`}
                class:list={[buttonBase, active ? buttonActive : buttonInactive]}
              >
                <span>{menu.label}</span>
                <svg
                  class="h-3.5 w-3.5 transition-transform"
                  data-tools-menu-chevron
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </button>

              <div
                id={`mk-menu-${menu.id}`}
                data-tools-menu
                data-menu-id={menu.id}
                role="menu"
                hidden
                class="absolute left-1/2 top-full z-40 mt-2 w-[min(92vw,360px)] -translate-x-1/2 rounded-lg border border-slate-200 bg-white p-2 shadow-xl ring-1 ring-black/5 dark:border-slate-800 dark:bg-slate-950 dark:ring-white/5"
              >
                {menu.subKinds ? (
                  <div class="space-y-2">
                    {menu.subKinds.map((sub) => {
                      const tools = toolsFor([sub.kind]);
                      if (tools.length === 0) return null;
                      return (
                        <div>
                          <div class="mb-1 px-2 text-[10px] font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-500">
                            {sub.label}
                          </div>
                          <ul class="flex flex-col">
                            {tools.map((t) => {
                              const isCurrent = t.slug === currentSlug;
                              return (
                                <li>
                                  <a
                                    href={t.slug}
                                    role="menuitem"
                                    aria-current={isCurrent ? "page" : undefined}
                                    class:list={[
                                      itemBase,
                                      isCurrent ? itemActive : itemInactive,
                                    ]}
                                  >
                                    <span>{t.label}</span>
                                    {isCurrent && (
                                      <svg
                                        class="h-3.5 w-3.5"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2.5"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        aria-hidden="true"
                                      >
                                        <path d="M20 6 9 17l-5-5" />
                                      </svg>
                                    )}
                                  </a>
                                </li>
                              );
                            })}
                          </ul>
                        </div>
                      );
                    })}
                  </div>
                ) : (
                  <ul class="flex flex-col">
                    {toolsFor(menu.kinds).map((t) => {
                      const isCurrent = t.slug === currentSlug;
                      return (
                        <li>
                          <a
                            href={t.slug}
                            role="menuitem"
                            aria-current={isCurrent ? "page" : undefined}
                            class:list={[
                              itemBase,
                              isCurrent ? itemActive : itemInactive,
                            ]}
                          >
                            <span>{t.label}</span>
                            {isCurrent && (
                              <svg
                                class="h-3.5 w-3.5"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                aria-hidden="true"
                              >
                                <path d="M20 6 9 17l-5-5" />
                              </svg>
                            )}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                )}
              </div>
            </div>
          );
        })
      }
    </nav>

    <button
      type="button"
      data-theme-toggle
      aria-label="Toggle theme"
      class="inline-flex h-9 w-9 shrink-0 cursor-pointer items-center justify-center rounded-md border border-slate-200 bg-white text-slate-600 transition-colors hover:bg-slate-50 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-slate-50"
    >
      <svg
        class="hidden h-4 w-4 dark:block"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path
          d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
        ></path>
      </svg>
      <svg
        class="h-4 w-4 dark:hidden"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>
  </div>
</header>

<script>
  function initToolsMenus() {
    const buttons = Array.from(
      document.querySelectorAll<HTMLButtonElement>(
        "[data-tools-menu-button]",
      ),
    );
    const panels = Array.from(
      document.querySelectorAll<HTMLElement>("[data-tools-menu]"),
    );
    if (buttons.length === 0) return;

    function findBtn(id: string | null) {
      return buttons.find((b) => b.dataset.menuId === id) ?? null;
    }
    function findPanel(id: string | null) {
      return panels.find((p) => p.dataset.menuId === id) ?? null;
    }

    function closeAll() {
      for (const btn of buttons) {
        btn.setAttribute("aria-expanded", "false");
        const chev = btn.querySelector<HTMLElement>("[data-tools-menu-chevron]");
        if (chev) chev.style.transform = "";
      }
      for (const panel of panels) panel.hidden = true;
    }

    function open(id: string) {
      closeAll();
      const btn = findBtn(id);
      const panel = findPanel(id);
      if (btn) {
        btn.setAttribute("aria-expanded", "true");
        const chev = btn.querySelector<HTMLElement>("[data-tools-menu-chevron]");
        if (chev) chev.style.transform = "rotate(180deg)";
      }
      if (panel) panel.hidden = false;
    }

    for (const btn of buttons) {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const id = btn.dataset.menuId ?? "";
        if (btn.getAttribute("aria-expanded") === "true") closeAll();
        else open(id);
      });
    }

    document.addEventListener("click", (e) => {
      const anyOpen = buttons.some(
        (b) => b.getAttribute("aria-expanded") === "true",
      );
      if (!anyOpen) return;
      const target = e.target as Node;
      const insideAny =
        buttons.some((b) => b.contains(target)) ||
        panels.some((p) => p.contains(target));
      if (!insideAny) closeAll();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      const activeBtn = buttons.find(
        (b) => b.getAttribute("aria-expanded") === "true",
      );
      if (!activeBtn) return;
      closeAll();
      activeBtn.focus();
    });
  }
  initToolsMenus();
</script>
