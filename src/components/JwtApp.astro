---
const cardCls =
  "flex flex-col gap-2 rounded-md border p-3";
const labelCls =
  "text-xs font-medium uppercase tracking-wide text-slate-700 dark:text-slate-300";
const copyCls =
  "inline-flex cursor-pointer items-center gap-1 rounded-md border border-emerald-200 bg-white px-1.5 py-0.5 text-[11px] font-medium text-emerald-700 transition-colors hover:bg-emerald-50 hover:text-emerald-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-400 focus-visible:ring-offset-1 dark:border-emerald-900/60 dark:bg-slate-950 dark:text-emerald-400 dark:hover:bg-emerald-950/40 dark:hover:text-emerald-300";
const taCls =
  "h-64 w-full resize-y rounded-md bg-white p-2 font-mono text-[12px] leading-relaxed text-slate-900 outline-none dark:bg-slate-950 dark:text-slate-100";
---

<div
  data-jwt-app
  class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm sm:p-6 dark:border-slate-800 dark:bg-slate-950"
>
  <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
    <label
      for="jwt-input"
      class="text-xs font-medium uppercase tracking-wide text-slate-500 dark:text-slate-400"
      >Encoded JWT</label
    >
    <button
      type="button"
      data-action="clear"
      aria-label="Clear input"
      title="Clear input"
      class="inline-flex h-7 w-7 cursor-pointer items-center justify-center rounded-md text-red-500/70 transition-colors hover:bg-red-50 hover:text-red-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-red-400 focus-visible:ring-offset-1 dark:text-red-400/70 dark:hover:bg-red-950/40 dark:hover:text-red-300"
    >
      <svg
        class="h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M3 6h18"></path>
        <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"></path>
        <path d="M10 11v6M14 11v6"></path>
      </svg>
    </button>
  </div>
  <textarea
    id="jwt-input"
    data-input
    placeholder="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxIn0.signature"
    spellcheck="false"
    autocomplete="off"
    autocorrect="off"
    autocapitalize="off"
    class="h-32 w-full resize-y rounded-md border border-slate-200 bg-slate-50 p-3 font-mono text-[13px] leading-relaxed text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-slate-400 focus:ring-2 focus:ring-slate-300 focus:ring-offset-1 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-100 dark:placeholder:text-slate-600 dark:focus:border-slate-600 dark:focus:ring-slate-700"
  ></textarea>

  <div
    role="alert"
    data-error
    hidden
    class="mt-4 rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700 dark:border-red-900/60 dark:bg-red-950/40 dark:text-red-300"
  >
  </div>

  <div class="mt-4 grid gap-4 md:grid-cols-3">
    <div class={`${cardCls} border-sky-200 dark:border-sky-900/60`}>
      <div class="flex items-center justify-between gap-2">
        <span class={labelCls}>Header</span>
        <button
          type="button"
          data-copy-target="[data-header]"
          aria-label="Copy header"
          class={copyCls}>Copy</button>
      </div>
      <textarea data-header readonly spellcheck="false" class={taCls}
      ></textarea>
    </div>

    <div class={`${cardCls} border-emerald-200 dark:border-emerald-900/60`}>
      <div class="flex items-center justify-between gap-2">
        <span class={labelCls}>Payload</span>
        <button
          type="button"
          data-copy-target="[data-payload]"
          aria-label="Copy payload"
          class={copyCls}>Copy</button>
      </div>
      <textarea data-payload readonly spellcheck="false" class={taCls}
      ></textarea>
    </div>

    <div class={`${cardCls} border-amber-200 dark:border-amber-900/60`}>
      <div class="flex items-center justify-between gap-2">
        <span class={labelCls}>Signature</span>
        <button
          type="button"
          data-copy-target="[data-signature]"
          aria-label="Copy signature"
          class={copyCls}>Copy</button>
      </div>
      <textarea data-signature readonly spellcheck="false" class={taCls}
      ></textarea>
    </div>
  </div>
</div>

<script>
  import { initJwt } from "~/scripts/jwt";
  initJwt();
</script>
