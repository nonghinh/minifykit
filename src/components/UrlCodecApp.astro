---
const toggleBtn =
  "inline-flex cursor-pointer items-center justify-center rounded-md px-3 py-1.5 text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2";
const toggleWrap =
  "inline-flex items-center gap-1 rounded-lg border border-slate-200 bg-slate-50 p-1 dark:border-slate-800 dark:bg-slate-900";
---

<div
  data-url-app
  class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm sm:p-6 dark:border-slate-800 dark:bg-slate-950"
>
  <div class="mb-4 flex flex-wrap items-center gap-3">
    <div role="group" aria-label="Mode" class={toggleWrap}>
      <button type="button" data-mode="encode" class={toggleBtn}>Encode</button>
      <button type="button" data-mode="decode" class={toggleBtn}>Decode</button>
    </div>
    <div role="group" aria-label="Scope" class={toggleWrap}>
      <button type="button" data-scope="component" class={toggleBtn}>
        Component
      </button>
      <button type="button" data-scope="full" class={toggleBtn}>Full URI</button>
    </div>
    <p class="text-xs text-slate-500 dark:text-slate-400">
      <strong class="font-semibold text-slate-700 dark:text-slate-300">Component</strong>
      encodes <code class="rounded bg-slate-100 px-1 font-mono text-[11px] dark:bg-slate-800">/ ? &amp; =</code> too — pick this for query string values.
    </p>
  </div>

  <div
    role="alert"
    data-error
    hidden
    class="mb-4 rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700 dark:border-red-900/60 dark:bg-red-950/40 dark:text-red-300"
  >
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <div class="flex flex-col gap-2">
      <div class="flex items-center justify-between gap-2">
        <label
          for="url-input"
          class="text-xs font-medium uppercase tracking-wide text-slate-500 dark:text-slate-400"
          >Input</label
        >
        <button
          type="button"
          data-action="clear"
          aria-label="Clear input"
          title="Clear input"
          class="inline-flex h-7 w-7 cursor-pointer items-center justify-center rounded-md text-red-500/70 transition-colors hover:bg-red-50 hover:text-red-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-red-400 focus-visible:ring-offset-1 dark:text-red-400/70 dark:hover:bg-red-950/40 dark:hover:text-red-300"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M3 6h18"></path>
            <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"></path>
            <path d="M10 11v6M14 11v6"></path>
          </svg>
        </button>
      </div>
      <textarea
        id="url-input"
        data-input
        placeholder="https://example.com/?q=hello world"
        spellcheck="false"
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        class="h-[50vh] min-h-[260px] w-full resize-y rounded-md border border-slate-200 bg-slate-50 p-3 font-mono text-[13px] leading-relaxed text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-slate-400 focus:ring-2 focus:ring-slate-300 focus:ring-offset-1 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-100 dark:placeholder:text-slate-600 dark:focus:border-slate-600 dark:focus:ring-slate-700"
      ></textarea>
    </div>

    <div class="flex flex-col gap-2">
      <div class="flex items-center justify-between gap-2">
        <label
          for="url-output"
          class="text-xs font-medium uppercase tracking-wide text-slate-500 dark:text-slate-400"
          >Output</label
        >
        <button
          type="button"
          data-action="copy"
          aria-label="Copy output"
          class="inline-flex cursor-pointer items-center gap-1.5 rounded-md border border-emerald-200 bg-white px-2 py-1 text-xs font-medium text-emerald-700 transition-colors hover:bg-emerald-50 hover:text-emerald-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-400 focus-visible:ring-offset-1 dark:border-emerald-900/60 dark:bg-slate-950 dark:text-emerald-400 dark:hover:bg-emerald-950/40 dark:hover:text-emerald-300"
        >
          <svg
            class="h-3.5 w-3.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="9" y="9" width="11" height="11" rx="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          Copy
        </button>
      </div>
      <textarea
        id="url-output"
        data-output
        readonly
        spellcheck="false"
        class="h-[50vh] min-h-[260px] w-full resize-y rounded-md border border-slate-200 bg-white p-3 font-mono text-[13px] leading-relaxed text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-slate-400 focus:ring-2 focus:ring-slate-300 focus:ring-offset-1 dark:border-slate-800 dark:bg-slate-950 dark:text-slate-100 dark:focus:border-slate-600 dark:focus:ring-slate-700"
      ></textarea>
    </div>
  </div>
</div>

<script>
  import { initUrlCodec } from "~/scripts/url-codec";
  initUrlCodec();
</script>
