---
import { getTool, type ToolId } from "~/lib/processors";
import Topbar from "~/components/Topbar.astro";

interface Props {
  toolId: ToolId;
}

const { toolId } = Astro.props;
const tool = getTool(toolId);
---

<div class="flex min-h-screen flex-col">
  <Topbar currentSlug={tool.slug} />

  <main
    class="mx-auto w-full max-w-6xl flex-1 px-4 py-6 sm:px-6 sm:py-8"
  >
    <div class="mb-6">
      <h1
        class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl dark:text-slate-50"
      >
        {tool.label}
      </h1>
      <p class="mt-2 max-w-3xl text-sm text-slate-600 dark:text-slate-400">
        {tool.intro}
      </p>
    </div>

    <slot name="tool" />

    <slot name="seo" />
  </main>

  <footer
    class="border-t border-slate-200 py-4 text-center text-xs text-slate-500 dark:border-slate-800 dark:text-slate-500"
  >
    Runs entirely in your browser · No uploads, no tracking
  </footer>

  <div
    data-toast-region
    aria-live="polite"
    aria-atomic="true"
    class="pointer-events-none fixed inset-x-0 top-28 z-50 flex flex-col items-center gap-2 px-4 md:top-20"
  >
  </div>
</div>
